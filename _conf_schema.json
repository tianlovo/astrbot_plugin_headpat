{
  "patpat": {
    "description": "摸头杀配置",
    "type": "object",
    "hint": "配置摸头杀相关的行为参数",
    "items": {
      "enable": {
        "description": "是否启用摸头杀",
        "type": "bool",
        "default": true,
        "hint": "关闭后，收到摸头指令时将不再执行摸头动作"
      },
      "speed": {
        "description": "摸头速度",
        "type": "float",
        "default": 1.0,
        "hint": "控制摸头动作的快慢，值越大越快。建议范围：0.5 ~ 3.0",
        "slider": {
          "min": 0.5,
          "max": 3.0,
          "step": 0.1
        }
      },
      "cooldown_seconds": {
        "description": "摸头冷却时间（秒）",
        "type": "float",
        "default": 3.0,
        "hint": "防止刷屏，两次摸头之间的最小间隔时间（秒）",
        "slider": {
          "min": 0,
          "max": 10,
          "step": 0.5
        }
      },
      "reply_text": {
        "description": "摸头回复文本",
        "type": "text",
        "default": "轻轻摸了摸你的头~",
        "hint": "执行摸头动作时回复的消息内容，可使用变量 {user} 表示被摸用户昵称"
      },
      "allowed_groups": {
        "description": "允许使用摸头功能的QQ群列表",
        "type": "list",
        "default": [],
        "hint": "只有在列表中的群才能触发摸头功能，为空则允许所有群"
      },
      "transparent_background": {
        "description": "启用透明背景",
        "type": "bool",
        "default": true,
        "hint": "启用后GIF背景为透明，不启用时可指定背景颜色"
      },
      "background_color": {
        "description": "背景颜色",
        "type": "string",
        "default": "#FFFFFF",
        "hint": "当不启用透明背景时，使用此颜色作为背景。支持十六进制颜色值，如 #FFFFFF（白色）、#000000（黑色）"
      },
      "cache_enabled": {
        "description": "启用GIF缓存",
        "type": "bool",
        "default": true,
        "hint": "启用后，生成的GIF会被缓存，避免重复生成"
      },
      "cache_ttl": {
        "description": "缓存有效期（秒）",
        "type": "int",
        "default": 3600,
        "hint": "缓存文件的有效期，超过此时间会被清理。0或负数表示永不过期。默认3600秒（1小时）"
      },
      "max_cache_size": {
        "description": "最大缓存数量",
        "type": "int",
        "default": 100,
        "hint": "最多缓存的GIF文件数量，超过时会按LRU策略清理。默认100个"
      },
      "auto_cleanup": {
        "description": "启用自动清理",
        "type": "bool",
        "default": true,
        "hint": "启用后，会定期自动清理过期的缓存文件"
      },
      "cleanup_interval": {
        "description": "自动清理间隔（秒）",
        "type": "int",
        "default": 3600,
        "hint": "自动清理任务的执行间隔。默认3600秒（1小时）"
      },
      "cleanup_on_startup": {
        "description": "启动时清理",
        "type": "bool",
        "default": false,
        "hint": "启用后，插件启动时会执行一次过期缓存清理"
      }
    }
  }
}
